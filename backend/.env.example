# Port number for the Express server to listen on (e.g., 4000)
PORT=4000

# Google Gemini API key used by the @google/genai SDK and LangChain to run inference models
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API key used by web search tool agents to perform real-time information retrieval
TAVILY_API_KEY=your_tavily_api_key_here

# Application environment stage (development, production, test)
NODE_ENV=development
